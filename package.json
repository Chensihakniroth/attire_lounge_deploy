{
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\"",
        "dev:css": "tailwindcss -i ./resources/css/app.css -o ./public/css/app.css --watch",
        "dev:js": "esbuild resources/js/app.jsx resources/js/admin.tsx --bundle --splitting --outdir=public/js --format=esm --watch --sourcemap --loader:.js=jsx --loader:.jsx=jsx --loader:.ts=tsx --loader:.tsx=tsx --public-path=./",
        "build": "npm run build:css && npm run build:js",
        "build:css": "tailwindcss -i ./resources/css/app.css -o ./public/css/app.css --minify",
        "build:js": "esbuild resources/js/app.jsx resources/js/admin.tsx --bundle --splitting --minify --outdir=public/js --format=esm --sourcemap --loader:.js=jsx --loader:.jsx=jsx --loader:.ts=tsx --loader:.tsx=tsx --public-path=./"
    },
    "dependencies": {
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tanstack/react-query": "^5.90.21",
        "axios": "^1.13.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lenis": "^1.3.17",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-dropzone": "^14.3.8",
        "react-helmet-async": "^2.0.5",
        "react-intersection-observer": "^10.0.3",
        "react-router-dom": "^6.20.1",
        "sweetalert2": "^11.26.24",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@headlessui/react": "^1.7.17",
        "@heroicons/react": "^2.0.18",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/postcss": "^4.2.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "esbuild": "^0.27.2",
        "framer-motion": "^10.18.0",
        "laravel-echo": "^2.3.0",
        "lucide-react": "^0.309.0",
        "postcss": "^8.5.8",
        "pusher-js": "^8.4.0",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.9.3"
    }
}
